<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0"
    ExtensionBundleId="com.marcy.pngseq"
    ExtensionBundleVersion="1.0.0"
    ExtensionBundleName="PNG 序列預覽"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <ExtensionList>
        <Extension Id="com.marcy.pngseq.panel" Version="1.0.0" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <!-- After Effects CC 2019 ~ 2025+ -->
            <Host Name="AEFT" Version="[16.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.marcy.pngseq.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./client/index.html</MainPath>
                    <ScriptPath>./host/host.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--allow-file-access-from-files</Parameter>
                        <Parameter>--allow-file-access</Parameter>
                        <Parameter>--disable-web-security</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>PNG 序列預覽</Menu>
                    <Geometry>
                        <Size>
                            <Height>620</Height>
                            <Width>420</Width>
                        </Size>
                        <MinSize>
                            <Height>460</Height>
                            <Width>340</Width>
                        </MinSize>
                        <MaxSize>
                            <Height>1400</Height>
                            <Width>900</Width>
                        </MaxSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
